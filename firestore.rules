rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() { return request.auth != null; }

    function hasRole(role) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated() &&
        exists(userPath) &&
        get(userPath).data.role == role;
    }
    
    function isCoordinator() {
      return hasRole('COORDINATOR');
    }

    function isOwner(userId) { return request.auth.uid == userId; }

    function canDispenseMeds() {
      return hasRole('COORDINATOR') || hasRole('PHARMACIST') || hasRole('DOCTOR');
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isCoordinator();
    }

    match /volunteer_profiles/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() &&
        (resource.data.userId == request.auth.uid || isCoordinator());
    }

    match /volunteer_presence/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.auth.uid == uid &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isCoordinator() || (
        isAuthenticated() &&
        request.auth.uid == uid &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.uid == resource.data.uid
      );
      allow delete: if isCoordinator() || (
        isAuthenticated() &&
        request.auth.uid == uid &&
        resource.data.uid == request.auth.uid
      );
    }

    match /raw_reports/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.submittedBy == request.auth.uid &&
        request.resource.data.clientEventId == docId;
      allow update: if isCoordinator() || (
        isAuthenticated() &&
        resource.data.submittedBy == request.auth.uid &&
        request.resource.data.submittedBy == resource.data.submittedBy &&
        request.resource.data.clientEventId == resource.data.clientEventId
      );
    }

    match /extracted_reports/{docId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isCoordinator();
    }

    match /outbox_events/{docId} {
      allow read: if isCoordinator() || (
        isAuthenticated() &&
        resource.data.submittedBy == request.auth.uid
      );
      allow create: if isAuthenticated() &&
        request.resource.data.submittedBy == request.auth.uid &&
        request.resource.data.clientEventId == docId &&
        request.resource.data.reportId == docId;
      allow update: if isCoordinator() || (
        isAuthenticated() &&
        resource.data.submittedBy == request.auth.uid &&
        request.resource.data.submittedBy == resource.data.submittedBy &&
        request.resource.data.clientEventId == resource.data.clientEventId &&
        request.resource.data.reportId == resource.data.reportId
      );
    }

    match /dispense_logs/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        canDispenseMeds() &&
        request.resource.data.dispensedBy == request.auth.uid;
      allow update, delete: if isCoordinator();
    }

    match /{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isCoordinator();
    }
  }
}
